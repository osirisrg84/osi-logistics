# Server port (set automatically by Render/Railway)
PORT=3001

# Comma-separated list of allowed frontend origins
FRONTEND_URL=https://your-app.vercel.app

# SQLite database file path (use /var/data/osi_logistics.db on Render with disk)
DATABASE_PATH=./osi_logistics.db

# Node environment
NODE_ENV=production

# Anthropic API key for the chat widget (get it at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...
